# Runtime
AUTH_ENABLED=false
PORT=8080
HOST_PORT=8083
CONTAINER_PORT=8080
POSTGRES_HOST=huff-postgres
POSTGRES_PORT=5432
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432
POSTGRES_DB=huff_wordle
POSTGRES_USER=huff
POSTGRES_PASSWORD=change-me
GAME_TIMEZONE=Europe/Rome
WORDLE_WORD_SEED=huff-it-wordle
COOKIE_SECURE=false

# Docker deploy
IMAGE_NAME=huff-italian-wordle
CONTAINER_NAME=huff-wordle
DATA_DIR=/root/huff/data
DOCKER_NETWORK=huff-wordle
POSTGRES_CONTAINER_NAME=huff-postgres
POSTGRES_DATA_DIR=/root/huff/data/postgres
POSTGRES_IMAGE=postgres:16-alpine

# Google OAuth, used only when AUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
