# Runtime
AUTH_ENABLED=false
PORT=8080
HOST_PORT=8083
CONTAINER_PORT=8080
DB_PATH=/data/huff-wordle.sqlite
GAME_TIMEZONE=Europe/Rome
WORDLE_WORD_SEED=huff-it-wordle
COOKIE_SECURE=false

# Docker deploy
IMAGE_NAME=huff-italian-wordle
CONTAINER_NAME=huff-wordle
DATA_DIR=/root/huff/data

# Google OAuth, used only when AUTH_ENABLED=true
APP_BASE_URL=http://localhost:8083
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
